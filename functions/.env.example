# NeonDB PostgreSQL connection string
# Get this from: https://console.neon.tech/ -> Your project -> Connection Details
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Google Gemini API key
# Get this from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Path to Google service account JSON file (for Calendar API)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# Download the JSON key and place it in this directory
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
